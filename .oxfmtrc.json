{
  "$schema": "./node_modules/oxfmt/schema.json",
  "printWidth": 80,
  "experimentalSortImports": {
    "groups": [
      ["type-import"],
      ["type-builtin", "value-builtin"],
      ["type-external", "value-external", "type-internal", "value-internal"],
      [
        "type-parent",
        "type-sibling",
        "type-index",
        "value-parent",
        "value-sibling",
        "value-index"
      ],
      ["unknown"]
    ],
    "newlinesBetween": true,
    "order": "asc"
  },
  "ignorePatterns": ["dist", "node_modules", ".husky"]
}
