{
  "$schema": "./node_modules/oxlint/schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "warn",
    "pedantic": "warn",
    "restriction": "off",
    "nursery": "off"
  },
  "plugins": ["unicorn"],
  "overrides": [
    {
      "files": ["__tests__/**/*.js", "**/*.test.js"],
      "plugins": ["vitest"]
    }
  ],
  "ignorePatterns": ["dist", "node_modules", ".husky"]
}
