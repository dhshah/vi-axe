{
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "warn",
    "pedantic": "warn",
    "restriction": "off",
    "nursery": "off"
  },
  "plugins": [
    "unicorn"
  ],
  "overrides": [
    {
      "files": ["__tests__/**/*.js", "**/*.test.js"],
      "plugins": ["vitest"]
    }
  ]
}
