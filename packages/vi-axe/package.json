{
  "name": "vi-axe",
  "version": "1.0.0",
  "description": "Modern Vitest matcher for aXe for testing accessibility using axe-core",
  "keywords": [
    "a11y",
    "accessibility",
    "axe",
    "matcher",
    "vitest"
  ],
  "license": "MIT",
  "author": "Darshan Shah",
  "repository": "dhshah/vi-axe",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extend-expect": {
      "types": "./dist/extend-expect.d.ts",
      "import": "./dist/extend-expect.js"
    }
  },
  "scripts": {
    "test": "vitest",
    "build": "vite build"
  },
  "dependencies": {
    "axe-core": "4.11.4",
    "lodash.merge": "4.6.2"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@testing-library/vue": "8.1.0",
    "@types/lodash.merge": "4.6.9",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vue/test-utils": "2.4.9",
    "jsdom": "29.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "typescript": "6.0.3",
    "unplugin-isolated-decl": "0.16.0",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vue": "3.5.33"
  },
  "engines": {
    "node": ">= 20.0.0"
  }
}
