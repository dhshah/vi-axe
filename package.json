{
  "name": "root",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "knip": "knip"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "knip": "^5.86.0",
    "lint-staged": "^16.0.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "oxlint --fix"
    ],
    "*.{json,md,yml,yaml,ts,tsx,js,jsx,cjs,mjs,cts,mts}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "packageManager": "pnpm@10"
}
