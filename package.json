{
  "name": "vi-axe",
  "version": "0.0.2-pre-alpha",
  "description": "Custom Vitest matcher for aXe for testing accessibility",
  "keywords": [
    "a11y",
    "accessibility",
    "axe",
    "matcher",
    "vitest"
  ],
  "license": "MIT",
  "author": "Darshan Shah",
  "repository": "dhshah/vi-axe",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extend-expect": {
      "types": "./dist/extend-expect.d.ts",
      "import": "./dist/extend-expect.js"
    },
    "./typings": {
      "types": "./dist/typings.d.ts"
    }
  },
  "scripts": {
    "prepare": "husky",
    "test": "vitest",
    "build": "vite build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "axe-core": "4.10.2",
    "jest-matcher-utils": "29.2.2",
    "lodash.merge": "4.6.2"
  },
  "devDependencies": {
    "@testing-library/react": "^13.4.0",
    "@testing-library/vue": "^6.6.1",
    "@types/lodash.merge": "^4.6.9",
    "@vue/test-utils": "^2.2.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.4.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.52.0",
    "oxlint-tsgolint": "^0.16.0",
    "prettier": "^2.7.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.9.3",
    "unplugin-isolated-decl": "^0.15.7",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue": "^3.2.41"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">= 16.0.0"
  },
  "packageManager": "pnpm@10"
}
